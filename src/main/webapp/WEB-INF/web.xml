    </servlet>
    <servlet-mapping>
        <servlet-name>cadastro</servlet-name>
        <url-pattern>/cadastro</url-pattern>
    </servlet-mapping>
    <!-- Servlet Transferencia -->
    <servlet>
        <servlet-name>transferencia</servlet-name>
        <servlet-class>com.mycompany.a.Transferencia</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>transferencia</servlet-name>
        <url-pattern>/transferencia</url-pattern>
    </servlet-mapping>
    
     <servlet>
        <servlet-name>saque</servlet-name>
        <servlet-class>com.mycompany.a.Saque</servlet-class>
    </servlet>
