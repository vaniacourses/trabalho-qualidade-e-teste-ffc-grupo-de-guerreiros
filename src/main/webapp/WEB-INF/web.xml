    <servlet>
        <servlet-name>investimento</servlet-name>
        <servlet-class>com.mycompany.a.Investimento</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>investimento</servlet-name>
        <url-pattern>/investimento</url-pattern>
    </servlet-mapping>
