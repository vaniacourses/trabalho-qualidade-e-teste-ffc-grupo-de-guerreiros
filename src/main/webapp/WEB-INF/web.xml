        <url-pattern>/extrato</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>deposito</servlet-name>
        <servlet-class>com.mycompany.a.Deposito</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>deposito</servlet-name>
        <url-pattern>/deposito</url-pattern>
    </servlet-mapping>
</web-app>
